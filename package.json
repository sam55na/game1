{
  "name": "battle-tanks-royale",
  "version": "8.0.0",
  "description": "🎮 Battle Tanks Royale - لعبة معركة دبابات متعددة اللاعبين عبر الإنترنت",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "admin:create": "node scripts/create-admin.js"
  },
  "keywords": [
    "battle-tanks",
    "game-server",
    "multiplayer",
    "socket.io",
    "battle-royale",
    "three.js",
    "postgresql",
    "telegram-game"
  ],
  "author": "Battle Tanks Team",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "pg": "^8.11.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcrypt": "^5.1.1",
    "jsonwebtoken": "^9.0.2",
    "crypto": "^1.0.1",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "connect-pg-simple": "^9.0.0",
    "redis": "^4.6.10",
    "bull": "^4.11.5",
    "winston": "^3.11.0",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "joi": "^17.11.0",
    "cron": "^3.1.6",
    "axios": "^1.6.2",
    "node-cron": "^3.0.3",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "faker": "^5.5.3",
    "dotenv-cli": "^7.3.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testMatch": [
      "**/__tests__/**/*.js",
      "**/?(*.)+(spec|test).js"
    ]
  },
  "eslintConfig": {
    "extends": "eslint:recommended",
    "env": {
      "node": true,
      "es6": true,
      "jest": true
    },
    "parserOptions": {
      "ecmaVersion": 2020
    },
    "rules": {
      "no-unused-vars": "warn",
      "no-console": "off",
      "no-async-promise-executor": "off",
      "no-constant-condition": "off"
    }
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "es5",
    "tabWidth": 2,
    "semi": true,
    "printWidth": 100,
    "arrowParens": "avoid"
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules",
      "data",
      "logs",
      "*.test.js"
    ],
    "watch": [
      "server.js",
      "src"
    ],
    "ext": "js,json",
    "delay": 1000,
    "env": {
      "NODE_ENV": "development"
    }
  }
}
